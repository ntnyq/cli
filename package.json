{
  "name": "ntnyq",
  "version": "0.4.1",
  "description": "The ntnyq CLI",
  "keywords": [
    "cli",
    "ntnyq"
  ],
  "license": "MIT",
  "author": "ntnyq <ntnyq@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ntnyq/cli.git"
  },
  "bin": "./dist/cli.mjs",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/cli.mjs",
  "exports": "./dist/cli.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "ink": "^7.0.5",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.1",
    "ink-link": "^5.0.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "open": "^11.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "^7.0.0-dev.20260607.1",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.8"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.2"
}
