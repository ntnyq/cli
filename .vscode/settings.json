{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "typescript.experimental.useTsgo": true,
  "cSpell.words": [
    "Bilibili",
    "bumpp",
    "changelogithub",
    "esbuild",
    "Juejin",
    "oxfmt",
    "oxlint",
    "pnpm",
    "sindresorhus",
    "tsdown",
    "tsgo",
    "unrs"
  ]
}
